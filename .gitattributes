# ── 기본값: 텍스트 파일은 LF로 정규화 ──────────────────────────
* text=auto eol=lf

# ── 웹 소스 (명시적 LF) ────────────────────────────────────────
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.json    text eol=lf

# ── Python ────────────────────────────────────────────────────
*.py      text eol=lf

# ── 문서 ──────────────────────────────────────────────────────
*.md      text eol=lf
*.txt     text eol=lf
*.yml     text eol=lf

# ── Windows 배치 파일: CRLF 유지 ──────────────────────────────
*.bat     text eol=crlf
*.cmd     text eol=crlf

# ── 바이너리 ──────────────────────────────────────────────────
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
